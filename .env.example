# PostgreSQL
POSTGRES_USER=cambioapp
POSTGRES_PASSWORD=cambioapp_dev
POSTGRES_DB=cambioapp
POSTGRES_PORT=5432

# Derived database URL (used by API directly)
DATABASE_URL=postgresql://cambioapp:cambioapp_dev@localhost:5432/cambioapp

# JWT secrets — generate with: openssl rand -hex 64
JWT_SECRET=change_this_in_production_please
JWT_REFRESH_SECRET=change_this_refresh_secret_too

# API
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Web
VITE_API_URL=http://localhost:4000
API_PORT=4000
WEB_PORT=5173

# Aviso de actualización del APK Android
# APP_VERSION_CODE = versionCode del ÚLTIMO APK publicado.
# La app muestra "hay actualización" solo si este número es MAYOR que el
# versionCode instalado en el celular. Por eso, al publicar un APK nuevo,
# subí este valor al mismo número del APK (ver apps/android/app/build.gradle.kts).
APP_VERSION_CODE=11
# URL directa de descarga del último APK (debe apuntar al APK nuevo).
APP_DOWNLOAD_URL=
